# ─────────────────────────────────────────────────────────────────────────────
# MediBook Frontend — .gitignore
# Stack: React 18, Vite, Tailwind CSS, Redux Toolkit
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Environment variables ─────────────────────────────────────────────────────
# Vite exposes VITE_* vars to the browser — never put secrets here,
# but still keep .env out of version control
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is intentionally NOT ignored — commit it as a safe template

# ── Vite build output ─────────────────────────────────────────────────────────
dist/
dist-ssr/

# ── Vite cache ────────────────────────────────────────────────────────────────
.vite/
.cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Test / Coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.sw?
